<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – Student Manager</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <style>
        :root {
            --primary: #1a237e;
            --accent:  #e91e63;
            --soft:    #f5f5f5;
        }
        body { background: var(--soft); font-family: 'Segoe UI', sans-serif; }

        /* ── Navbar ── */
        .navbar { background: var(--primary) !important; }
        .navbar-brand { font-weight: 700; font-size: 1.4rem; letter-spacing: .5px; }
        .navbar-brand span { color: var(--accent); }

        /* ── Cards ── */
        .card { border: none; border-radius: 12px; box-shadow: 0 2px 16px rgba(0,0,0,.08); }
        .card-header {
            background: var(--primary);
            color: #fff;
            border-radius: 12px 12px 0 0 !important;
            padding: 1rem 1.5rem;
        }

        /* ── Buttons ── */
        .btn-primary   { background: var(--primary); border-color: var(--primary); }
        .btn-primary:hover { background: #283593; border-color: #283593; }
        .btn-danger    { background: var(--accent);  border-color: var(--accent); }
        .btn-danger:hover  { background: #c2185b;    border-color: #c2185b; }

        /* ── Table ── */
        .table thead th { background: var(--primary); color: #fff; border: none; }
        .table tbody tr:hover { background: #e8eaf6; }

        /* ── Alerts ── */
        .toast-success {
            position: fixed; top: 1.5rem; right: 1.5rem;
            z-index: 9999; min-width: 300px;
        }

        /* ── Form labels ── */
        label.form-label { font-weight: 600; color: var(--primary); }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container">
            <a class="navbar-brand text-white" asp-controller="Students" asp-action="Index">
                <i class="fas fa-graduation-cap me-2"></i>Student<span>Manager</span>
            </a>
        </div>
    </nav>

    <div class="container my-4">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible toast-success fade show shadow" role="alert">
                <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
