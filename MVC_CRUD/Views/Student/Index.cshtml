@model IEnumerable<Student>
@{
    ViewData["Title"] = "Students";
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="fas fa-users me-2"></i>All Students</h5>
        <a asp-action="Create" class="btn btn-light btn-sm">
            <i class="fas fa-plus me-1"></i> Add New
        </a>
    </div>
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="fas fa-user-slash fa-3x mb-3"></i>
                <p>No students yet. <a asp-action="Create">Add the first one!</a></p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Name</th>
                            <th>Age</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>Created</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in Model)
                        {
                            <tr>
                                <td class="text-muted">@s.Id</td>
                                <td><strong>@s.Name</strong></td>
                                <td>@s.Age</td>
                                <td>
                                    <a href="mailto:@s.Email" class="text-decoration-none">@s.Email</a>
                                </td>
                                <td>@s.Phone</td>
                                <td class="text-muted small">@s.CreatedAt.ToString("MMM dd, yyyy")</td>
                                <td class="text-center">
                                    <a asp-action="Details" asp-route-id="@s.Id"
                                       class="btn btn-sm btn-outline-info me-1" title="Details">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@s.Id"
                                       class="btn btn-sm btn-outline-primary me-1" title="Edit">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@s.Id"
                                       class="btn btn-sm btn-outline-danger" title="Delete">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="p-3 text-muted small border-top">
                Total: <strong>@Model.Count()</strong> student(s)
            </div>
        }
    </div>
</div>
