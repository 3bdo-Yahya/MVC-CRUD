@model Student
@{
    ViewData["Title"] = "Student Details";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="fas fa-id-card me-2"></i>Student Profile</h5>
                <span class="badge bg-light text-dark">#@Model.Id</span>
            </div>
            <div class="card-body p-4">

                <div class="text-center mb-4">
                    <div class="rounded-circle bg-primary d-inline-flex align-items-center justify-content-center"
                         style="width:80px;height:80px;">
                        <span class="text-white fw-bold fs-2">@Model.Name[0]</span>
                    </div>
                    <h4 class="mt-3 mb-0">@Model.Name</h4>
                    <small class="text-muted">Enrolled @Model.CreatedAt.ToString("MMMM dd, yyyy")</small>
                </div>

                <hr />

                <dl class="row">
                    <dt class="col-sm-4 text-muted"><i class="fas fa-calendar me-1"></i> Age</dt>
                    <dd class="col-sm-8">@Model.Age years</dd>

                    <dt class="col-sm-4 text-muted"><i class="fas fa-envelope me-1"></i> Email</dt>
                    <dd class="col-sm-8">
                        <a href="mailto:@Model.Email">@Model.Email</a>
                    </dd>

                    <dt class="col-sm-4 text-muted"><i class="fas fa-phone me-1"></i> Phone</dt>
                    <dd class="col-sm-8">@Model.Phone</dd>
                </dl>

                <div class="d-flex gap-2 mt-4">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
                        <i class="fas fa-edit me-1"></i> Edit
                    </a>
                    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">
                        <i class="fas fa-trash me-1"></i> Delete
                    </a>
                    <a asp-action="Index" class="btn btn-outline-secondary ms-auto">
                        <i class="fas fa-arrow-left me-1"></i> Back
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
