@model IEnumerable<Visual.Models.Course>
@{
    ViewData["Title"] = "Courses";
}

<div class="card shadow-sm">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="fas fa-book-open me-2"></i>Course Catalog</h5>
        <a asp-action="Create" class="btn btn-light btn-sm fw-bold">
            <i class="fas fa-plus-circle me-1"></i> Add New Course
        </a>
    </div>
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="fas fa-layer-group fa-3x mb-3 text-secondary"></i>
                <p class="fs-5">No courses available yet.</p>
                <a asp-action="Create" class="btn btn-primary btn-sm">Create the first course</a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3">Course</th>
                            <th>Instructor</th>
                            <th>Price</th>
                            <th>Hours</th>
                            <th>Created Date</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-3">
                                    <div class="d-flex align-items-center">
                                        <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center me-3" style="width: 35px; height: 35px;">
                                            @item.Title[0]
                                        </div>
                                        <span class="fw-bold">@item.Title</span>
                                    </div>
                                </td>
                                <td><i class="fas fa-user-tie me-1 text-muted"></i> @item.Instructor</td>
                                <td><span class="badge bg-success">@item.Price.ToString("C")</span></td>
                                <td>@item.Hours <small class="text-muted">hrs</small></td>
                                <td class="text-muted small">@item.CreatedAt.ToString("MMM dd, yyyy")</td>
                                <td class="text-center">
                                    <div class="btn-group">
                                        <a asp-action="Details" asp-route-id="@item.Id"
                                           class="btn btn-sm btn-outline-info" title="View">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.Id"
                                           class="btn btn-sm btn-outline-primary" title="Edit">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id"
                                           class="btn btn-sm btn-outline-danger" title="Delete">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="p-3 text-muted small border-top bg-light">
                Total Available Courses: <strong>@Model.Count()</strong>
            </div>
        }
    </div>
</div>
