@model Visual.Models.Course
@{
    ViewData["Title"] = "Course Details";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card shadow-sm">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="fas fa-info-circle me-2"></i>Course Information</h5>
                <span class="badge bg-light text-dark">ID: #@Model.Id</span>
            </div>
            <div class="card-body p-4">

                <div class="text-center mb-4">
                    <div class="rounded-circle bg-success d-inline-flex align-items-center justify-content-center"
                         style="width:80px;height:80px;">
                        <span class="text-white fw-bold fs-2">@Model.Title[0]</span>
                    </div>
                    <h4 class="mt-3 mb-0">@Model.Title</h4>
                    <small class="text-muted">Created on @Model.CreatedAt.ToString("MMMM dd, yyyy")</small>
                </div>

                <hr />

                <dl class="row px-3">
                    <dt class="col-sm-4 text-muted"><i class="fas fa-chalkboard-teacher me-1"></i> Instructor</dt>
                    <dd class="col-sm-8 fw-bold text-primary">@Model.Instructor</dd>

                    <dt class="col-sm-4 text-muted"><i class="fas fa-dollar-sign me-1"></i> Price</dt>
                    <dd class="col-sm-8 text-success fw-bold">$@Model.Price</dd>

                    <dt class="col-sm-4 text-muted"><i class="fas fa-clock me-1"></i> Duration</dt>
                    <dd class="col-sm-8">@Model.Hours Hours</dd>

                    <dt class="col-sm-4 text-muted"><i class="fas fa-align-left me-1"></i> Description</dt>
                    <dd class="col-sm-8">
                        <p class="text-muted mb-0">@Model.Description</p>
                    </dd>
                </dl>

                <div class="d-flex gap-2 mt-4 border-top pt-3">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
                        <i class="fas fa-edit me-1"></i> Edit Course
                    </a>
                    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">
                        <i class="fas fa-trash me-1"></i> Delete
                    </a>
                    <a asp-action="Index" class="btn btn-outline-secondary ms-auto">
                        <i class="fas fa-arrow-left me-1"></i> Back to List
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
