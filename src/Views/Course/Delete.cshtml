@model Visual.Models.Course
@{
    ViewData["Title"] = "Delete Course";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-danger shadow-sm">
            <div class="card-header bg-danger text-white">
                <h5 class="mb-0"><i class="fas fa-exclamation-triangle me-2"></i>Confirm Delete</h5>
            </div>
            <div class="card-body p-4 text-center">
                <div class="mb-3">
                    <i class="fas fa-book fa-4x text-danger"></i>
                </div>
                <h5>Are you sure you want to delete this course?</h5>
                <p class="text-muted">This action <strong>cannot be undone</strong>.</p>

                <div class="card bg-light mt-3 mb-4">
                    <div class="card-body py-3">
                        <h6 class="mb-1 text-primary"><strong>@Model.Title</strong></h6>
                        <p class="text-muted mb-0 small">
                            Instructor: @Model.Instructor &nbsp;|&nbsp;
                            Price: $@Model.Price &nbsp;|&nbsp;
                            Duration: @Model.Hours hrs
                        </p>
                    </div>
                </div>

                <form asp-action="Delete" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    
                    <div class="d-flex gap-2 justify-content-center">
                        <button type="submit" class="btn btn-danger px-4">
                            <i class="fas fa-trash me-1"></i> Yes, Delete
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary px-4">
                            <i class="fas fa-times me-1"></i> Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
