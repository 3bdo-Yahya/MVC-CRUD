<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LMS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark lms-navbar shadow-sm">
        <div class="container">
            <a class="navbar-brand text-white fw-semibold" asp-controller="Home" asp-action="Index">
                <i class="fas fa-book-reader me-2"></i>LMS
            </a>
            <div class="navbar-nav ms-auto">
                <a class="nav-link text-white" asp-controller="Home" asp-action="Index">
                    <i class="fas fa-chart-line me-1"></i>Dashboard
                </a>
                <a class="nav-link text-white" asp-controller="Books" asp-action="Index">
                    <i class="fas fa-book-open me-1"></i>Books
                </a>
            </div>
        </div>
    </nav>

    <div class="container my-4">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible toast-success fade show shadow-sm border-0" role="alert">
                <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @RenderBody()
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
