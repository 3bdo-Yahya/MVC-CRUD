@model Book
@{
    ViewData["Title"] = "Delete Book";
}

<div class="mb-4">
    <a asp-action="Index" class="text-secondary text-decoration-none"><i class="fa-solid fa-arrow-left me-1"></i> Back to Books</a>
</div>

<div class="card lms-card lms-card--danger">
    <div class="card-body text-center py-5">
        <div class="lms-danger-icon mb-3">
            <i class="fa-solid fa-trash-can"></i>
        </div>
        <h3 class="fw-700 mb-2">Delete this book?</h3>
        <p class="text-secondary mb-1">This action cannot be undone.</p>
        <p class="mb-4">
            <strong>@Model.Title</strong> <span class="text-secondary">by @Model.Author</span>
        </p>
        <form asp-action="Delete" method="post" class="d-inline-flex gap-2">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger px-4">Yes, Delete</button>
            <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
        </form>
    </div>
</div>
