@model Book
@{
    ViewData["Title"] = "Delete Book";
}

<div class="card lms-card border border-danger-subtle">
    <div class="card-body">
        <h3 class="text-danger mb-3">Delete Book</h3>
        <p class="mb-3">Are you sure you want to delete this book?</p>

        <div class="mb-3">
            <strong>@Model.Title</strong> by @Model.Author
        </div>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">Delete</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </form>
    </div>
</div>
