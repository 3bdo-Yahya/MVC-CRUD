@model BookFormViewModel

<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

<div class="row g-3">
    <div class="col-md-6">
        <label asp-for="Title" class="form-label fw-medium">Title</label>
        <input asp-for="Title" class="form-control" placeholder="e.g. Clean Code" />
        <span asp-validation-for="Title" class="text-danger small"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="Author" class="form-label fw-medium">Author</label>
        <input asp-for="Author" class="form-control" placeholder="e.g. Robert C. Martin" />
        <span asp-validation-for="Author" class="text-danger small"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="Genre" class="form-label fw-medium">Genre</label>
        <input asp-for="Genre" class="form-control" placeholder="e.g. Software Engineering" />
        <span asp-validation-for="Genre" class="text-danger small"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="PublishedYear" class="form-label fw-medium">Published Year</label>
        <input asp-for="PublishedYear" class="form-control" placeholder="e.g. 2008" />
        <span asp-validation-for="PublishedYear" class="text-danger small"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="CopiesAvailable" class="form-label fw-medium">Copies Available</label>
        <input asp-for="CopiesAvailable" class="form-control" placeholder="e.g. 3" />
        <span asp-validation-for="CopiesAvailable" class="text-danger small"></span>
    </div>
</div>
