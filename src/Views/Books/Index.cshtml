@model IEnumerable<Book>
@{
    ViewData["Title"] = "Books";
    var searchTerm = ViewData["SearchTerm"]?.ToString();
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
    <div>
        <h1 class="lms-page-title">Books</h1>
        <p class="text-secondary mb-0">Browse, search, and manage the catalog.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary px-3">
        <i class="fa-solid fa-plus me-2"></i>New Book
    </a>
</div>

<div class="card lms-card">
    <div class="card-body">
        <form method="get" class="d-flex gap-2 mb-3">
            <div class="position-relative flex-grow-1">
                <i class="fa-solid fa-magnifying-glass lms-search-icon"></i>
                <input type="text" class="form-control lms-search-input" name="searchTerm" value="@searchTerm" placeholder="Search by title or author..." />
            </div>
            <button type="submit" class="btn btn-primary">Search</button>
            @if (!string.IsNullOrEmpty(searchTerm))
            {
                <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
            }
        </form>

        @if (!Model.Any())
        {
            <div class="lms-empty-state">
                <i class="fa-regular fa-folder-open"></i>
                <p>No books found.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table lms-table align-middle mb-0">
                    <thead>
                    <tr>
                        <th>Title</th>
                        <th>Author</th>
                        <th>Genre</th>
                        <th>Year</th>
                        <th>Copies</th>
                        <th class="text-end">Actions</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-medium">@item.Title</td>
                            <td>@item.Author</td>
                            <td><span class="badge badge-soft">@item.Genre</span></td>
                            <td>@item.PublishedYear</td>
                            <td>@item.CopiesAvailable</td>
                            <td class="text-end text-nowrap">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Details</a>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
