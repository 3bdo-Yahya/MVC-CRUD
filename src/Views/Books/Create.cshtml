@model BookFormViewModel
@{
    ViewData["Title"] = "Add Book";
}

<div class="mb-4">
    <a asp-action="Index" class="text-secondary text-decoration-none"><i class="fa-solid fa-arrow-left me-1"></i> Back to Books</a>
</div>

<div class="card lms-card">
    <div class="card-body">
        <h2 class="fw-700 mb-1">New Book</h2>
        <p class="text-secondary mb-4">Fill in the details to add a book to the catalog.</p>
        <form asp-action="Create" method="post">
            <partial name="_BookFormFields" model="Model" />
            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary px-4">Create</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}
